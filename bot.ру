from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup, ReplyKeyboardMarkup
from telegram.ext import Application, CommandHandler, MessageHandler, CallbackQueryHandler, filters, ContextTypes
from telegram.constants import ParseMode

# ==================== КОНФИГУРАЦИЯ ====================
BOT_TOKEN = "8605483965:AAHExXC7Yyd8U5ke0g5g-LRGG_tAnBteZ1E"
ADMIN_ID = 8032626504
ADMIN_USERNAME = "@vultures_maniac"
DB_NAME = "main_data.db"

# ==================== БАЗА ДАННЫХ ====================
def init_db():
    with sqlite3.connect(DB_NAME) as conn:
        c = conn.cursor()
        # Юзеры и экономика
        c.execute('''CREATE TABLE IF NOT EXISTS users (
            user_id INTEGER PRIMARY KEY,
            balance INTEGER DEFAULT 5,
            premium_until TEXT,
            last_bonus TEXT,
            ref_id INTEGER
        )''')
        # Контент
        c.execute('''CREATE TABLE IF NOT EXISTS content (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            type TEXT,
            file_id TEXT
        )''')
        conn.commit()

init_db()

# ==================== КЛАВИАТУРЫ ====================
def get_main_keyboard():
    return ReplyKeyboardMarkup([
        ['🎬 Видео (2 💎)', '🖼 Фото (1 💎)'],
        ['👤 Профиль', '🎁 Бонус'],
        ['🤝 Друзья', '🆘 Поддержка']
    ], resize_keyboard=True)

# ==================== ОБРАБОТЧИКИ ====================

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user = update.effective_user
    args = context.args
    ref_id = int(args[0]) if args and args[0].isdigit() else None

    with sqlite3.connect(DB_NAME) as conn:
        c = conn.cursor()
        c.execute('SELECT 1 FROM users WHERE user_id = ?', (user.id,))
        if not c.fetchone():
            c.execute('INSERT INTO users (user_id, ref_id) VALUES (?, ?)', (user.id, ref_id))
            if ref_id:
                c.execute('UPDATE users SET balance = balance + 3 WHERE user_id = ?', (ref_id,))
                try: await context.bot.send_message(ref_id, "💎 +3 алмаза за друга!")
                except: pass
            conn.commit()

    await update.message.reply_text(
        "👋 **Добро пожаловать!**\nВыбирай контент или копи алмазы.",
        reply_markup=get_main_keyboard(),
        parse_mode=ParseMode.MARKDOWN
    )

async def handle_text(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    text = update.message.text

    # Проверка режима ответа админа
    if user_id == ADMIN_ID and context.user_data.get('answering_to'):
        target_id = context.user_data.get('answering_to')
        try:
            await context.bot.send_message(target_id, f"✉️ **Ответ администрации:**\n\n{text}", parse_mode=ParseMode.MARKDOWN)
            await update.message.reply_text("✅ Ответ отправлен!")
        except: await update.message.reply_text("❌ Ошибка отправки.")
        context.user_data.pop('answering_to', None)
        return

    # Логика кнопок
    if text == '👤 Профиль':
        with sqlite3.connect(DB_NAME) as conn:
            row = conn.execute('SELECT balance, premium_until FROM users WHERE user_id = ?', (user_id,)).fetchone()
            prem = row[1] if row[1] else "Нет"
            await update.message.reply_text(f"👤 **Профиль**\n\n💰 Баланс: `{row[0]}` 💎\n👑 Премиум: `{prem}`", parse_mode=ParseMode.MARKDOWN)

    elif text == '🎁 Бонус':
        today = str(date.today())
        with sqlite3.connect(DB_NAME) as conn:
            row = conn.execute('SELECT last_bonus, premium_until FROM users WHERE user_id = ?', (user_id,)).fetchone()
            if row[0] == today:
                return await update.message.reply_text("❌ Бонус уже взят!")
            
            is_prem = row[1] and row[1] > datetime.now().isoformat()
            reward = 15 if is_prem else 5
            conn.execute('UPDATE users SET balance = balance + ?, last_bonus = ? WHERE user_id = ?', (reward, today, user_id))
            conn.commit()
            await update.message.reply_text(f"✅ Получено {reward} 💎")

    elif text == '🤝 Друзья':
        bot_info = await context.bot.get_me()
        link = f"https://t.me/{bot_info.username}?start={user_id}"
        await update.message.reply_text(f"🤝 Приглашай друзей и получай 3 💎!\n\nТвоя ссылка:\n`{link}`", parse_mode=ParseMode.MARKDOWN)

    elif 'Видео' in text or 'Фото' in text:
        c_type = 'video' if 'Видео' in text else 'photo'
        cost = 2 if c_type == 'video' else 1
        
        with sqlite3.connect(DB_NAME) as conn:
            row = conn.execute('SELECT balance FROM users WHERE user_id = ?', (user_id,)).fetchone()
            if row[0] < cost:
                return await update.message.reply_text("❌ Недостаточно алмазов!")
            
            content = conn.execute('SELECT file_id FROM content WHERE type = ? ORDER BY RANDOM() LIMIT 1', (c_type,)).fetchone()
            if not content:
                return await update.message.reply_text("📦 База пока пуста.")
            
            conn.execute('UPDATE users SET balance = balance - ? WHERE user_id = ?', (cost, user_id))
            conn.commit()
            
            if c_type == 'video': await update.message.reply_video(content[0])
            else: await update.message.reply_photo(content[0])

    elif text == '🆘 Поддержка':
        await update.message.reply_text("Напиши свой вопрос или предложку одним сообщением:")

    # Если просто текст (Поддержка)
    elif user_id != ADMIN_ID:
        kb = InlineKeyboardMarkup([[InlineKeyboardButton("📨 Ответить", callback_data=f"ans_{user_id}")]])
        await context.bot.send_message(ADMIN_ID, f"📩 **Сообщение от {user_id}:**\n\n{text}", reply_markup=kb, parse_mode=ParseMode.MARKDOWN)
        await update.message.reply_text("✅ Сообщение отправлено админу.")

# ==================== АДМИН КОМАНДЫ ====================

async def admin_panel(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID: return
    kb = InlineKeyboardMarkup([
        [InlineKeyboardButton("📥 Загрузить видео", callback_data="up_video")],
        [InlineKeyboardButton("📥 Загрузить фото", callback_data="up_photo")]
    ])
    await update.message.reply_text("🛠 **Админка**", reply_markup=kb, parse_mode=ParseMode.MARKDOWN)

async def button_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    
    if query.data.startswith("ans_"):
        context.user_data['answering_to'] = query.data.split("_")[1]
        await query.message.reply_text("✍️ Введи ответ пользователю:")
    
    elif query.data.startswith("up_"):
        context.user_data['upload_mode'] = query.data.split("_")[1]
        await query.message.reply_text(f"📥 Режим загрузки {context.user_data['upload_mode']}. Шли файлы. Чтобы выйти — /start")

async def handle_media(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID: return
    mode = context.user_data.get('upload_mode')
    if not mode: return

    with sqlite3.connect(DB_NAME) as conn:
        if update.message.photo and mode == 'photo':
            conn.execute('INSERT INTO content (type, file_id) VALUES (?, ?)', ('photo', update.message.photo[-1].file_id))
        elif update.message.video and mode == 'video':
            conn.execute('INSERT INTO content (type, file_id) VALUES (?, ?)', ('video', update.message.video.file_id))
        conn.commit()
    await update.message.reply_text("➕ Добавлено в базу")

# ==================== ЗАПУСК ====================
def main():
    app = Application.builder().token(BOT_TOKEN).build()
    
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("admin", admin_panel))
    app.add_handler(CallbackQueryHandler(button_callback))
    app.add_handler(MessageHandler(filters.PHOTO | filters.VIDEO, handle_media))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_text))
    
    print("Бот запущен!")
    app.run_polling(drop_pending_updates=True)

if __name__ == "__main__":
    main()