# ==================== БАЗА ДАННЫХ ====================
def init_db():
    with sqlite3.connect(DB_NAME) as conn:
        c = conn.cursor()
        c.execute('''CREATE TABLE IF NOT EXISTS users (
            user_id INTEGER PRIMARY KEY, balance INTEGER DEFAULT 5,
            premium_until TEXT, last_bonus TEXT, ref_id INTEGER)''')
        c.execute('''CREATE TABLE IF NOT EXISTS content (
            id INTEGER PRIMARY KEY AUTOINCREMENT, type TEXT, file_id TEXT)''')
        conn.commit()

init_db()

