@dp.message(Command("reply"), F.from_user.id == ADMIN_ID)
async def cmd_reply(message: types.Message):
    p = message.text.split(maxsplit=2)
    if len(p) == 3:
        await bot.send_message(p[1], f"✉️ **Ответ администрации:**\n\n{p[2]}", parse_mode="Markdown")
        await message.answer("✅ Отправлено")

@dp.message(F.text, ~F.text.startswith("/"))
async def auto_support(message: types.Message):
    if message.from_user.id != ADMIN_ID:
        await bot.send_message(ADMIN_ID, f"📩 **Сообщение от** `{message.from_user.id}`:\n\n{message.text}\n\nОтвет: `/reply {message.from_user.id} текст`", parse_mode="Markdown")

async def main():
    await init_db()
    await bot.set_my_commands([BotCommand(command="start", description="Запуск")])
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())