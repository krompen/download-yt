# --- ОБРАБОТЧИКИ ---

@dp.message(CommandStart())
async def cmd_start(message: types.Message):
    async with db.execute("SELECT user_id FROM users WHERE user_id = ?", (message.from_user.id,)) as c:
        if not await c.fetchone():
            await db.execute("INSERT INTO users (user_id) VALUES (?)", (message.from_user.id,))
            await db.commit()
    await message.answer("✨ Бот запущен и готов к работе!", reply_markup=main_kb(message.from_user.id))

@dp.message(F.text.contains("👤 Профиль"))
async def profile(message: types.Message):
    async with db.execute("SELECT balance, premium_until FROM users WHERE user_id = ?", (message.from_user.id,)) as c:
        row = await c.fetchone()
        bal, prem = row[0], row[1]
        status = f"🌟 Премиум до {prem[:10]}" if prem and prem > datetime.now().isoformat() else "Обычный"
        await message.answer(f"👤 **Твой профиль**\n\n💰 Баланс: `{bal}` 💎\n👑 Статус: {status}", parse_mode="Markdown")

@dp.message(F.text.contains("🎁 Бонус"))
async def daily_bonus(message: types.Message):
    today = str(date.today())
    async with db.execute("SELECT last_bonus, premium_until FROM users WHERE user_id = ?", (message.from_user.id,)) as c:
        row = await c.fetchone()
        if row[0] == today:
            return await message.answer("❌ Вы уже забирали бонус сегодня!")
        
        is_prem = row[1] and row[1] > datetime.now().isoformat()
        reward = 15 if is_prem else 5
        await db.execute("UPDATE users SET balance = balance + ?, last_bonus = ? WHERE user_id = ?", (reward, today, message.from_user.id))
        await db.commit()
        await message.answer(f"✅ Получено {reward} 💎!")

@dp.message(F.text.contains("Видео") | F.text.contains("Фото"))
async def get_content(message: types.Message):
    c_type = "video" if "Видео" in message.text else "photo"
    cost = 2 if c_type == "video" else 1
    
    async with db.execute("SELECT balance FROM users WHERE user_id = ?", (message.from_user.id,)) as c:
        bal = (await c.fetchone())[0]
        if bal < cost: return await message.answer("❌ Недостаточно 💎")

    async with db.execute("SELECT file_id FROM content WHERE type = ? ORDER BY RANDOM() LIMIT 1", (c_type,)) as c:
        res = await c.fetchone()
        if not res: return await message.answer("Контента пока нет.")
        
        await db.execute("UPDATE users SET balance = balance - ? WHERE user_id = ?", (cost, message.from_user.id))
        await db.commit()
        
        if c_type == "video":
            await message.answer_video(res[0], caption="🎬 Приятного просмотра!")
        else:
            await message.answer_photo(res[0], caption="🖼 Приятного просмотра!")

# --- АДМИНКА ---
@dp.message(F.text == "🛠 Админ Панель", F.from_user.id == ADMIN_ID)
async def admin_panel(message: types.Message):
    await message.answer("💻 **Управление ботом**", reply_markup=admin_kb(), parse_mode="Markdown")

@dp.callback_query(F.data == "adm_upload")
async def adm_upload(call: types.CallbackQuery, state: FSMContext):
    await state.set_state(Form.uploading)
    await call.message.answer("📥 **Режим массовой загрузки**\nПрисылай файлы. В конце напиши `/stop`", parse_mode="Markdown")
    await call.answer()

@dp.message(Form.uploading)
async def process_mass_upload(message: types.Message, state: FSMContext):
    if message.text == "/stop":
        await state.clear()
        return await message.answer("✅ Загрузка завершена", reply_markup=main_kb(ADMIN_ID))
    
    if message.photo:
        await db.execute("INSERT INTO content (type, file_id) VALUES (?, ?)", ("photo", message.photo[-1].file_id))
    elif message.video:
        await db.execute("INSERT INTO content (type, file_id) VALUES (?, ?)", ("video", message.video.file_id))
    await db.commit()
    await message.answer("➕")

@dp.callback_query(F.data == "adm_give_prem")
async def give_prem_call(call: types.CallbackQuery, state: FSMContext):
    await state.set_state(Form.giving_prem)
    await call.message.answer("Введите данные в формате: `ID ДНИ`", parse_mode="Markdown")
    await call.answer()

@dp.message(Form.giving_prem)
async def give_prem_proc(message: types.Message, state: FSMContext):
    try:
        uid, days = message.text.split()
        until = (datetime.now() + timedelta(days=int(days))).isoformat()
        await db.execute("UPDATE users SET premium_until = ? WHERE user_id = ?", (until, uid))
        await db.commit()
        await message.answer(f"✅ Премиум выдан пользователю {uid}")
    except:
        await message.answer("❌ Ошибка формата. Пример: `1234567 30`")
    await state.clear()

