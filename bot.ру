# ==================== ОБРАБОТЧИКИ ====================

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user = update.effective_user
    ref_id = int(context.args[0]) if context.args and context.args[0].isdigit() else None

    with sqlite3.connect(DB_NAME) as conn:
        c = conn.cursor()
        c.execute('SELECT 1 FROM users WHERE user_id = ?', (user.id,))
        if not c.fetchone():
            c.execute('INSERT INTO users (user_id, ref_id) VALUES (?, ?)', (user.id, ref_id))
            if ref_id:
                conn.execute('UPDATE users SET balance = balance + 3 WHERE user_id = ?', (ref_id,))
                try: await context.bot.send_message(ref_id, "💎 **+3 алмаза** за друга!")
                except: pass
            conn.commit()

    await update.message.reply_text(
        f"🌟 **Привет!**\nПодпишись на резерв: {RESERVE_LINK}",
        reply_markup=main_kb(), parse_mode=ParseMode.MARKDOWN
    )

async def handle_message(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    text = update.message.text
    
    # 1. Логика Админа (Ответы, Рассылка, Выдача Према)
    if user_id == ADMIN_ID:
        if context.user_data.get('awaiting_ans'):
            target = context.user_data.get('awaiting_ans')
            try:
                await context.bot.send_message(target, f"✉️ **Ответ администрации:**\n\n{text}", parse_mode=ParseMode.MARKDOWN)
                await update.message.reply_text("✅ Ответ отправлен!")
            except: await update.message.reply_text("❌ Ошибка отправки.")
            context.user_data.clear()
            return

        if context.user_data.get('awaiting_broadcast'):
            await update.message.reply_text("🚀 Рассылка запущена...")
            with sqlite3.connect(DB_NAME) as conn:
                users = conn.execute('SELECT user_id FROM users').fetchall()
            for u in users:
                try:
                    await context.bot.send_message(u[0], text, parse_mode=ParseMode.MARKDOWN)
                    await asyncio.sleep(0.05)
                except: continue
            await update.message.reply_text("🏁 Готово!")
            context.user_data.clear()
            return

        if context.user_data.get('awaiting_prem'):
            try:
                uid, days = text.split()
                until = (datetime.now() + timedelta(days=int(days))).isoformat()
                with sqlite3.connect(DB_NAME) as conn:
                    conn.execute('UPDATE users SET premium_until = ? WHERE user_id = ?', (until, uid))
                    conn.commit()
                await update.message.reply_text(f"✅ Премиум выдан юзеру `{uid}` на {days} дн.")
            except: await update.message.reply_text("❌ Ошибка. Формат: `ID ДНИ`")
            context.user_data.clear()
            return

    # 2. Кнопки меню
    if text == '👤 Профиль':
        with sqlite3.connect(DB_NAME) as conn:
            bal, prem = conn.execute('SELECT balance, premium_until FROM users WHERE user_id = ?', (user_id,)).fetchone()
        is_p = prem and prem > datetime.now().isoformat()
        status = f"💎 PREMIUM до {prem[:10]}" if is_p else "Обычный"
        msg = f"👤 **ПРОФИЛЬ**\n\n🆔 ID: `{user_id}`\n💰 Баланс: `{bal}` 💎\n👑 Статус: {status}\n🔗 Резерв: {RESERVE_LINK}"
        await update.message.reply_text(msg, parse_mode=ParseMode.MARKDOWN)

    elif text == '🎁 Бонус':
        today = str(date.today())
        with sqlite3.connect(DB_NAME) as conn:
            row = conn.execute('SELECT last_bonus, premium_until FROM users WHERE user_id = ?', (user_id,)).fetchone()
            if row[0] == today: return await update.message.reply_text("❌ Жди завтра!")
            is_p = row[1] and row[1] > datetime.now().isoformat()
            reward = 15 if is_p else 5
            conn.execute('UPDATE users SET balance = balance + ?, last_bonus = ? WHERE user_id = ?', (reward, today, user_id))
            conn.commit()
            await update.message.reply_text(f"🎁 +{reward} 💎!")

    elif text == '👑 Премиум':
        kb = InlineKeyboardMarkup([
            [InlineKeyboardButton("⭐ 1 День (15 ⭐️)", callback_data="buy_1"),
             InlineKeyboardButton("⭐ 7 Дней (75 ⭐️)", callback_data="buy_7")],
            [InlineKeyboardButton("⭐ 30 Дней (250 ⭐️)", callback_data="buy_30")],
            [InlineKeyboardButton("💳 Написать @gossnet", url="https://t.me/gossnet")]
        ])
        await update.message.reply_text(f"👑 **ТАРИФЫ**\n\nВыбери период оплаты звездами или пиши в ЛС.\nРезерв: {RESERVE_LINK}", reply_markup=kb, parse_mode=ParseMode.MARKDOWN)

    elif 'Видео' in text or 'Фото' in text:
        ctype = 'video' if 'Видео' in text else 'photo'
        cost = 2 if ctype == 'video' else 1
        with sqlite3.connect(DB_NAME) as conn:
            bal = conn.execute('SELECT balance FROM users WHERE user_id = ?', (user_id,)).fetchone()[0]
            if bal < cost: return await update.message.reply_text("❌ Мало алмазов!")
            res = conn.execute('SELECT file_id FROM content WHERE type = ? ORDER BY RANDOM() LIMIT 1', (ctype,)).fetchone()
            if not res: return await update.message.reply_text("📦 Пусто.")
            conn.execute('UPDATE users SET balance = balance - ? WHERE user_id = ?', (cost, user_id))
            conn.commit()
            await (update.message.reply_video(res[0]) if ctype == 'video' else update.message.reply_photo(res[0]))

    elif text == '🆘 Поддержка':
        await update.message.reply_text("💬 Напиши свой вопрос админу прямо здесь:")

    elif user_id != ADMIN_ID:
        # Техподдержка: пересылка админу
        kb = InlineKeyboardMarkup([[InlineKeyboardButton("📨 Ответить", callback_data=f"ans_{user_id}")]])
        await context.bot.send_message(ADMIN_ID, f"📩 **Новое сообщение!**\nID: `{user_id}`\n\n{text}", reply_markup=kb, parse_mode=ParseMode.MARKDOWN)
        await update.message.reply_text("✅ Отправлено админу!")

async def admin_cmd(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID: return
    kb = InlineKeyboardMarkup([
        [InlineKeyboardButton("📥 Загрузка", callback_data="adm_up"), 
         InlineKeyboardButton("📢 Рассылка", callback_data="adm_bc")],
        [InlineKeyboardButton("💎 Выдать Премиум", callback_data="adm_prem")]
    ])
    await update.message.reply_text("🛠 **Админ-панель**", reply_markup=kb, parse_mode=ParseMode.MARKDOWN)

async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    data = query.data

    if data == "adm_up":
        context.user_data['upload'] = True
        await query.message.reply_text("📥 Кидай медиа. Выход — /start")
    elif data == "adm_bc":
        context.user_data['awaiting_broadcast'] = True
        await query.message.reply_text("📢 Пиши текст для рассылки:")
    elif data == "adm_prem":
        context.user_data['awaiting_prem'] = True
        await query.message.reply_text("💎 Введи: `ID ДНИ` (например: `12345 30`)")
    elif data.startswith("ans_"):
        context.user_data['awaiting_ans'] = int(data.split("_")[1])
        await query.message.reply_text(f"✍️ Пиши ответ для {context.user_data['awaiting_ans']}:")
    elif data.startswith("buy_"):
        days = {"1": 15, "7": 75, "30": 250}[data.split("_")[1]]
        await context.bot.send_invoice(query.message.chat_id, "Premium", f"{data.split('_')[1]} дн.", data, "", "XTR", [LabeledPrice("Цена", days)])

# ==================== МЕДИА И ОПЛАТА ====================

async def handle_media(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID or not context.user_data.get('upload'): return
    with sqlite3.connect(DB_NAME) as conn:
        f_id = update.message.video.file_id if update.message.video else update.message.photo[-1].file_id
        conn.execute('INSERT INTO content (type, file_id) VALUES (?, ?)', ('video' if update.message.video else 'photo', f_id))
        conn.commit()
    await update.message.reply_text("✅ +1")

async def precheckout(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.pre_checkout_query.answer(ok=True)

async def success_pay(update: Update, context: ContextTypes.DEFAULT_TYPE):
    days = int(update.message.successful_payment.invoice_payload.split("_")[1])
    until = (datetime.now() + timedelta(days=days)).isoformat()
    with sqlite3.connect(DB_NAME) as conn:
        conn.execute('UPDATE users SET premium_until = ? WHERE user_id = ?', (until, update.effective_user.id))
        conn.commit()
    await update.message.reply_text(f"✅ Премиум на {days} дн. активен!")

# ==================== ЗАПУСК ====================
def main():
    app = Application.builder().token(BOT_TOKEN).build()
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("admin", admin_cmd))
    app.add_handler(CallbackQueryHandler(button_handler))
    app.add_handler(PreCheckoutQueryHandler(precheckout))
    app.add_handler(MessageHandler(filters.SUCCESSFUL_PAYMENT, success_pay))
    app.add_handler(MessageHandler(filters.PHOTO | filters.VIDEO, handle_media))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_message))
    app.run_polling(drop_pending_updates=True)

if __name__ == "__main__": main()