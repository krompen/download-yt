# ==================== ОБРАБОТЧИКИ ====================

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user = update.effective_user
    ref_id = int(context.args[0]) if context.args and context.args[0].isdigit() else None

    with sqlite3.connect(DB_NAME) as conn:
        c = conn.cursor()
        c.execute('SELECT 1 FROM users WHERE user_id = ?', (user.id,))
        if not c.fetchone():
            c.execute('INSERT INTO users (user_id, ref_id) VALUES (?, ?)', (user.id, ref_id))
            if ref_id:
                conn.execute('UPDATE users SET balance = balance + 3 WHERE user_id = ?', (ref_id,))
                try: await context.bot.send_message(ref_id, "💎 **+3 алмаза** за друга!")
                except: pass
            conn.commit()

    text = (f"🌟 **Привет, {user.first_name}!**\n\n"
            f"Добро пожаловать. Подпишись на наш резерв, чтобы не потерять доступ:\n"
            f"🔗 {RESERVE_LINK}")
    
    await update.message.reply_text(text, reply_markup=main_kb(user.id), parse_mode=ParseMode.MARKDOWN, disable_web_page_preview=True)

async def handle_main(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    text = update.message.text

    if user_id == ADMIN_ID:
        if context.user_data.get('ans_id'):
            target = context.user_data.get('ans_id')
            try:
                await context.bot.send_message(target, f"✉️ **Ответ администрации:**\n\n{text}", parse_mode=ParseMode.MARKDOWN)
                await update.message.reply_text("✅ Отправлено!")
            except: await update.message.reply_text("❌ Ошибка доставки.")
            context.user_data.pop('ans_id')
            return
        
        if context.user_data.get('broadcast'):
            await update.message.reply_text("🚀 Рассылка пошла...")
            with sqlite3.connect(DB_NAME) as conn:
                users = conn.execute('SELECT user_id FROM users').fetchall()
            count = 0
            for u in users:
                try:
                    await context.bot.send_message(u[0], text, parse_mode=ParseMode.MARKDOWN)
                    count += 1
                    await asyncio.sleep(0.05)
                except: continue
            await update.message.reply_text(f"🏁 Рассылка окончена. Получили: {count} чел.")
            context.user_data.pop('broadcast')
            return

    if text == '👤 Профиль':
        with sqlite3.connect(DB_NAME) as conn:
            bal, prem = conn.execute('SELECT balance, premium_until FROM users WHERE user_id = ?', (user_id,)).fetchone()
        is_p = prem and prem > datetime.now().isoformat()
        status = f"💎 PREMIUM (до {prem[:10]})" if is_p else "Обычный юзер"
        msg = (f"👤 **ВАШ ПРОФИЛЬ**\n━━━━━━━━━━━━━━\n"
               f"🆔 ID: `{user_id}`\n💰 Баланс: `{bal}` 💎\n👑 Статус: {status}\n\n"
               f"📢 Резерв: {RESERVE_LINK}\n"
               f"🆘 Админ: {ADMIN_CONTACT}")
        await update.message.reply_text(msg, parse_mode=ParseMode.MARKDOWN, disable_web_page_preview=True)

    elif text == '👑 Премиум':
        kb = InlineKeyboardMarkup([
            [InlineKeyboardButton("⭐ 1 День + 15 💎 (15 ⭐️)", callback_data="buy_1")],
            [InlineKeyboardButton("⭐ 7 Дней + 100 💎 (75 ⭐️)", callback_data="buy_7")],
            [InlineKeyboardButton("⭐ 30 Дней + 500 💎 (250 ⭐️)", callback_data="buy_30")],
            [InlineKeyboardButton("💳 Личка @gossnet", url=f"https://t.me/gossnet")]
        ])
        msg = (f"👑 **ТАРИФЫ PREMIUM**\n\n"
               f"— Бонус: **15 💎** ежедневно\n"
               f"— Полный доступ к базе\n"
               f"— Ссылка на резерв: {RESERVE_LINK}")
        await update.message.reply_text(msg, reply_markup=kb, parse_mode=ParseMode.MARKDOWN, disable_web_page_preview=True)

    elif 'Видео' in text or 'Фото' in text:
        ctype = 'video' if 'Видео' in text else 'photo'
        cost = 2 if ctype == 'video' else 1
        with sqlite3.connect(DB_NAME) as conn:
            bal = conn.execute('SELECT balance FROM users WHERE user_id = ?', (user_id,)).fetchone()[0]
            if bal < cost: return await update.message.reply_text("❌ Мало 💎. Жми Бонус или зови Друзей!")
            res = conn.execute('SELECT file_id FROM content WHERE type = ? ORDER BY RANDOM() LIMIT 1', (ctype,)).fetchone()
            if not res: return await update.message.reply_text("📦 База пуста.")
            conn.execute('UPDATE users SET balance = balance - ? WHERE user_id = ?', (cost, user_id))
            conn.commit()
            cap = f"🔗 {RESERVE_LINK}"
            if ctype == 'video': await update.message.reply_video(res[0], caption=cap)
            else: await update.message.reply_photo(res[0], caption=cap)

    elif text == '🛠 Админ Панель' and user_id == ADMIN_ID:
        with sqlite3.connect(DB_NAME) as conn:
            total = conn.execute('SELECT COUNT(*) FROM users').fetchone()[0]
            vids = conn.execute('SELECT COUNT(*) FROM content WHERE type="video"').fetchone()[0]
            imgs = conn.execute('SELECT COUNT(*) FROM content WHERE type="photo"').fetchone()[0]
        kb = InlineKeyboardMarkup([
            [InlineKeyboardButton("📥 Загрузить медиа", callback_data="adm_up")],
            [InlineKeyboardButton("📢 Рассылка", callback_data="adm_bc")]
        ])
        stats = f"📊 **СТАТИСТИКА**\n\nЮзеров: `{total}`\nВидео: `{vids}`\nФото: `{imgs}`"
        await update.message.reply_text(stats, reply_markup=kb, parse_mode=ParseMode.MARKDOWN)

    elif text == '🆘 Поддержка':
        await update.message.reply_text(f"💬 Напиши сообщение админу:")

    elif user_id != ADMIN_ID:
        kb = InlineKeyboardMarkup([[InlineKeyboardButton("📨 Ответить", callback_data=f"ans_{user_id}")]])
        await context.bot.send_message(ADMIN_ID, f"📩 **Сообщение!**\nОт: `{user_id}`\n\n{text}", reply_markup=kb)
        await update.message.reply_text("✅ Отправлено!")

# ==================== ОПЛАТА ====================

async def send_invoice(update: Update, context: ContextTypes.DEFAULT_TYPE, days, price, diamonds):
    query = update.callback_query
    await context.bot.send_invoice(
        chat_id=query.message.chat_id,
        title=f"Premium: {days} дн.",
        description=f"Доступ и +{diamonds} 💎",
        payload=f"p_{days}_{diamonds}",
        provider_token="",
        currency="XTR",
        prices=[LabeledPrice("💳", price)]
    )

async def precheckout(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.pre_checkout_query.answer(ok=True)

async def success_pay(update: Update, context: ContextTypes.DEFAULT_TYPE):
    uid = update.effective_user.id
    _, days, diamonds = update.message.successful_payment.invoice_payload.split("_")
    until = (datetime.now() + timedelta(days=int(days))).isoformat()
    with sqlite3.connect(DB_NAME) as conn:
        conn.execute('UPDATE users SET premium_until = ?, balance = balance + ? WHERE user_id = ?', (until, int(diamonds), uid))
        conn.commit()
    await update.message.reply_text(f"🎉 **Готово!** Активировано на {days} дн. +{diamonds} 💎")

# ==================== КНОПКИ И МЕДИА ====================

async def callbacks(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    d = query.data
    if d == "adm_up":
        context.user_data['upload'] = True
        await query.message.reply_text("📥 Шли файлы. Выход — /start")
    elif d == "adm_bc":
        context.user_data['broadcast'] = True
        await query.message.reply_text("📢 Пиши текст рассылки:")
    elif d == "buy_1": await send_invoice(update, context, 1, 15, 15)
    elif d == "buy_7": await send_invoice(update, context, 7, 75, 100)
    elif d == "buy_30": await send_invoice(update, context, 30, 250, 500)
    elif d.startswith("ans_"):
        context.user_data['ans_id'] = d.split("_")[1]
        await query.message.reply_text("✍️ Пиши ответ:")

async def handle_media(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID or not context.user_data.get('upload'): return
    with sqlite3.connect(DB_NAME) as conn:
        if update.message.photo:
            conn.execute('INSERT INTO content (type, file_id) VALUES (?, ?)', ('photo', update.message.photo[-1].file_id))
        elif update.message.video:
            conn.execute('INSERT INTO content (type, file_id) VALUES (?, ?)', ('video', update.message.video.file_id))
        conn.commit()
    await update.message.reply_text("✅ +1")

def main():
    app = Application.builder().token(BOT_TOKEN).build()
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CallbackQueryHandler(callbacks))
    app.add_handler(PreCheckoutQueryHandler(precheckout))
    app.add_handler(MessageHandler(filters.SUCCESSFUL_PAYMENT, success_pay))
    app.add_handler(MessageHandler(filters.PHOTO | filters.VIDEO, handle_media))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_main))
    app.run_polling(drop_pending_updates=True)

if __name__ == "__main__": main()
